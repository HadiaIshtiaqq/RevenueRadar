# ── AI (required) ─────────────────────────────────────────────────────────────
# Get your key at https://aimlapi.com — supports gpt-4o-mini, gpt-4o, claude-3, llama-3
AIML_API_KEY=your_aiml_api_key_here
AIML_MODEL=gpt-4o-mini

# Legacy Gemini key (no longer used — kept for reference)
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Bright Data (required for live web data) ───────────────────────────────────
# Get your API token at https://brightdata.com/cp/setting
BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# Bright Data zone names — must match zones created in your Bright Data dashboard
BRIGHTDATA_SERP_ZONE=serp_api2           # SERP API: Google/Bing/Yandex structured results
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1   # Web Unlocker: bypass bot detection on any URL
BRIGHTDATA_BROWSER_ZONE=scraping_browser1 # Scraping Browser: full JS rendering (create in dashboard)

# Bright Data MCP server URL — unlocks LinkedIn, Crunchbase, and 40+ structured dataset scrapers
# Get your token at: https://brightdata.com/cp/api_tokens
# Format: https://mcp.brightdata.com/

sse?token=<YOUR_TOKEN>
BRIGHTDATA_MCP_URL=

# ── SerpAPI (required for n8n market research workflow) ───────────────────────
# Get your key at https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# ── Speechmatics (optional — audio transcription for earnings calls / interviews) ──
# Get a free API key at https://app.speechmatics.com/
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here

# ── Slack Alerts (optional) ────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Google Maps (optional — dashboard intel map) ──────────────────────────────
# Enable Maps JavaScript API + enable billing at console.cloud.google.com
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── TriggerWare.ai (optional — automated workflow triggers) ───────────────────
# Get a free webhook at https://triggerware.ai
# When competitor signals score 75+ impact, RevenueRadarAI fires this webhook automatically.
TRIGGERWARE_WEBHOOK_URL=https://app.triggerware.ai/hooks/your_hook_id

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
